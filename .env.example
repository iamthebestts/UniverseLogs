# UniverseLogs — Environment configuration
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/logsdb
# Max simultaneous connections (default: 10)
DB_MAX_CONNECTIONS=10
# Idle connection timeout in seconds (default: 30) — prevents connection thrashing
DB_IDLE_TIMEOUT=30
# SSL: true/false | no-verify (accept cert without validation — use with caution)
# If unset: remote => SSL required, local => no SSL
DB_SSL=
# Prepared statements: true/false
# If unset: Supabase => false, others => true
DB_PREPARE_STATEMENTS=
# By default we force DNS resolution with IPv4 priority.
# Set to true to disable this behavior (opt-out).
DB_DISABLE_FORCE_IPV4=false

# --- Authentication & Security ---
# REQUIRED: A strong secret key for admin operations (/internal)
MASTER_KEY=your-secret-master-key-here

# --- Server ---
# Environment: dev (pretty-logs, detailed errors) | prod (json-logs, standard errors)
NODE_ENV=dev
PORT=3000
HOST=0.0.0.0

# --- Business logic (Universes / Tenants) ---
# Auto-create a Universe in the DB when receiving the first log?
AUTO_CREATE_UNIVERSE=true
# Fetch metadata (name, description) from public Roblox API?
FETCH_ROBLOX_API=true

# --- Infrastructure ---
# Run Drizzle migrations automatically on startup?
# WARNING: In production with multiple instances, disable this to avoid race conditions.
# Recommended: run migrations as a separate step in the deploy pipeline or use distributed locks.
RUN_MIGRATE=false
