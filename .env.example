# logs-api — Variáveis de ambiente
# Copie para .env e configure. Não commite .env.

# Obrigatórias
DATABASE_URL=postgresql://user:password@localhost:5432/logsdb
# REQUIRED: set MASTER_KEY to a strong secret before deployment
MASTER_KEY=your-secret-master-key-here

# Deploy: true = app roda migrações na subida; false = migrações rodadas por CI/pessoa (veja docs/deploy.md)
RUN_MIGRATE=true

# Servidor (Docker/Discloud: use PORT=8080 e HOST=0.0.0.0)
PORT=3000
HOST=0.0.0.0
USE_AUTH=true

# Universos (criar ao primeiro log; enriquecimento opcional via API Roblox)
AUTO_CREATE_UNIVERSE=true
FETCH_ROBLOX_API=true

# Ambiente: dev (erros verbosos) | prod — exemplo usa dev por padrão para evitar rodar em produção por engano
NODE_ENV=dev
