# logs-api — Configurações de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env para o controle de versão.

# --- Banco de Dados (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/logsdb
# Max conexões simultâneas (padrão: 10)
DB_MAX_CONNECTIONS=10
# Timeout de conexões inativas em segundos (padrão: 30) - prevent connection thrashing
DB_IDLE_TIMEOUT=30

# --- Autenticação e Segurança ---
# REQUIRED: Uma chave secreta forte para operações administrativas (/internal)
MASTER_KEY=your-secret-master-key-here

# --- Configurações do Servidor ---
# Ambiente: dev (pretty-logs, detailed errors) | prod (json-logs, standard errors)
NODE_ENV=dev
PORT=3000
HOST=0.0.0.0

# --- Lógica de Negócio (Universos/Tenants) ---
# Cria automaticamente um Universo no banco ao receber o primeiro log?
AUTO_CREATE_UNIVERSE=true
# Tenta buscar metadados (nome, descrição) via API pública do Roblox?
FETCH_ROBLOX_API=true

# --- Infraestrutura ---
# Executa as migrações do Drizzle automaticamente na inicialização?
# AVISO: Em produção com múltiplas instâncias, desabilite esta opção para evitar condições de corrida.
# Recomendado executar migrações como um passo separado no pipeline de deploy ou usar travas distribuídas.
RUN_MIGRATE=false
