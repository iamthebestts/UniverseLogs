{
  "name": "logs-api",
  "description": "Serviço de ingestão e consulta de logs estruturados com isolamento multi-tenant por UniverseId, voltado para jogos Roblox e aplicações distribuídas.",
  "version": "1.0.50",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "private": true,
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "migrate": "bunx drizzle-kit migrate --config ./drizzle.config.ts",
    "dev": "bun run --watch --env-file .env.development src/index.ts",
    "start": "bun run --env-file .env ."
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.2",
    "@elysiajs/eden": "latest",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/ui": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8",
    "vitest": "^1.0.0"
  }
}