{
  "name": "UniverseLogs",
  "description": "API de Ingestão e Consulta de Logs Estruturados de Alta Performance com isolamento multi-tenant nativo, otimizada para jogos distribuídos e microsserviços.",
  "version": "1.0.0",
  "license": "MIT",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "private": true,
  "scripts": {
    "test": "vitest run --config vitest.config.unit.ts tests/",
    "test:ui": "vitest --ui --config vitest.config.unit.ts tests/",
    "test:coverage": "vitest run --coverage --config vitest.config.unit.ts tests/",
    "test:watch": "vitest --watch --config vitest.config.unit.ts tests/",
    "test:e2e": "NODE_ENV=test vitest run --config vitest.config.e2e.ts e2e-tests/",
    "lint": "biome lint ./src ./tests",
    "format": "biome format ./src ./tests --write",
    "check": "biome check ./src ./tests",
    "type-check": "tsc --noEmit",
    "migrate": "bunx drizzle-kit migrate --config ./drizzle.config.ts",
    "dev": "bun run --watch --env-file .env.development src/index.ts",
    "start": "bun run --env-file .env .",
    "benchmark": "bun run scripts/benchmark.ts"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/swagger": "^1.3.1",
    "@sinclair/typebox": "0.34.48",
    "@types/ws": "^8.18.1",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.25",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "bun-types": "^1.3.9",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "ws": "^8.18.0"
  }
}
