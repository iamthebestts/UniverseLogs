{
  "name": "logs-api",
  "description": "API de Ingestão e Consulta de Logs Estruturados de Alta Performance com isolamento multi-tenant nativo, otimizada para jogos distribuídos e microsserviços.",
  "version": "1.0.0",
  "license": "MIT",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "private": true,
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "NODE_ENV=test vitest run --config vitest.config.e2e.ts",
    "migrate": "bunx drizzle-kit migrate --config ./drizzle.config.ts",
    "dev": "bun run --watch --env-file .env.development src/index.ts",
    "start": "bun run --env-file .env ."
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/swagger": "^1.3.1",
    "@elysiajs/websocket": "0.2.8",
    "@sinclair/typebox": "0.34.48",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "1.1.26",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/ui": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "bun-types": "^1.3.9",
    "drizzle-kit": "^0.31.9",
    "vitest": "^4.0.18"
  }
}